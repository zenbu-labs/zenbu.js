{
  "name": "@zenbujs/core",
  "version": "0.5.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/setup-gate.mjs",
  "bin": {
    "zen": "./dist/cli/bin.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./plugin-sources.css": "./dist/plugin-sources.css",
    "./setup-gate": {
      "types": "./dist/setup-gate.d.mts",
      "import": "./dist/setup-gate.mjs"
    },
    "./build": {
      "types": "./dist/cli/build.d.mts",
      "import": "./dist/cli/build.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./install-guard": {
      "types": "./dist/install-guard.d.mts",
      "import": "./dist/install-guard.mjs"
    },
    "./loaders/zenbu": {
      "types": "./dist/loaders/zenbu.d.mts",
      "import": "./dist/loaders/zenbu.mjs"
    },
    "./env-bootstrap": {
      "types": "./dist/env-bootstrap.d.mts",
      "import": "./dist/env-bootstrap.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./registry": {
      "types": "./dist/registry.d.mts",
      "import": "./dist/registry.mjs"
    },
    "./registry-generated": {
      "types": "./dist/registry-generated.d.mts",
      "import": "./dist/registry-generated.mjs"
    },
    "./events": {
      "types": "./dist/events.d.mts",
      "import": "./dist/events.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs"
    },
    "./services": {
      "types": "./dist/services/index.d.mts",
      "import": "./dist/services/index.mjs"
    },
    "./services/default": {
      "types": "./dist/services/default.d.mts",
      "import": "./dist/services/default.mjs"
    },
    "./boot-trace": {
      "types": "./dist/boot-trace.d.mts",
      "import": "./dist/boot-trace.mjs"
    },
    "./prelude/boot-trace": {
      "types": "./dist/prelude/boot-trace.d.mts",
      "import": "./dist/prelude/boot-trace.mjs"
    },
    "./db": {
      "types": "./dist/db.d.mts",
      "import": "./dist/db.mjs"
    },
    "./rpc": {
      "types": "./dist/rpc.d.mts",
      "import": "./dist/rpc.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "import": "./dist/react.mjs"
    },
    "./advice": {
      "types": "./dist/advice.d.mts",
      "import": "./dist/advice.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "migrations",
    "package.json"
  ],
  "scripts": {
    "build": "node --max-old-space-size=8192 ./node_modules/tsdown/dist/run.mjs",
    "prebuild": "pnpm link:types",
    "dev": "tsdown --watch",
    "link:types": "tsx ./src/cli/bin.ts link --types-config ./zenbu-types.config.json --out ./src/registry-generated.ts --augment-out ./types/zenbu-register.ts",
    "db:generate": "node ./dist/cli/bin.mjs db generate --schema src/schema.ts --migrations ./migrations",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "electron": "^42.0.0",
    "react": ">=18",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@zenbujs/hmr": "workspace:*",
    "effect": "^3.21.1",
    "electron-context-menu": "^4.1.2",
    "isomorphic-git": "^1.37.6",
    "nanoid": "^5.1.6",
    "semver": "^7.8.0",
    "tsx": "4.19.4",
    "vite": "^6.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.0",
    "@zenbu/advice": "workspace:*",
    "@zenbu/kyju": "workspace:*",
    "@zenbu/zenrpc": "workspace:*",
    "electron": "^42.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4",
    "zod": "^4"
  }
}
