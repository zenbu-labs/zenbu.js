{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@zenbujs/core": [
        "./src/index.ts"
      ],
      "@zenbujs/core/registry": [
        "./src/registry.ts"
      ],
      "@zenbujs/core/registry-generated": [
        "./src/registry-generated.ts"
      ],
      "@zenbujs/core/runtime": [
        "./src/runtime.ts"
      ],
      "@zenbujs/core/services": [
        "./src/services/index.ts"
      ],
      "@zenbujs/core/events": [
        "./src/events.ts"
      ],
      "@zenbujs/core/schema": [
        "./src/schema.ts"
      ],
      "@zenbujs/core/db": [
        "./src/db.ts"
      ],
      "#registry/*": [
        "./types/*"
      ]
    }
  },
  "include": [
    "src",
    "types",
    "tsdown.config.ts"
  ]
}
